<section id="contact">
    <h2>Contact Me</h2>

    <form action="#" method="post">

        <p>
            <label for="name">Name:</label><br>
            <input
                type="text"
                id="name"
                name="name"
                required>
        </p>

        <p>
            <label for="email">Email:</label><br>
            <input
                type="email"
                id="email"
                name="email"
                required>
        </p>

        <p>
            <label for="message">Message:</label><br>
            <textarea
                id="message"
                name="message"
                rows="6"
                cols="40"
                required></textarea>
        </p>

        <p>
            <button type="submit">Send Message</button>
        </p>

    </form>

</section>

